# ──────────────────────────────────────────────
# Lost Ark Discord Bot – Environment Variables
# Copy this file to .env and fill in the values.
# On Railway: set these in the project's Variables tab (do NOT upload .env).
# ──────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# The text channel ID where online notifications will be sent
CHANNEL_ID=your_channel_id_here

# The role ID to mention when Brelshaza comes online
ROLE_ID=your_role_id_here

# Approver Discord user IDs for /la-list add approval flow (comma-separated)
OFFICER_APPROVER_IDS=id1,id2,id3
SENIOR_APPROVER_IDS=id1,id2
MEMBER_APPROVER_IDS=id1

# Optional: global fallback channel IDs for auto-checking screenshots (comma-separated)
# Per-server config: use /la-setup autochannel #channel instead
# AUTO_CHECK_CHANNEL_IDS=channel_id_1,channel_id_2

# Optional: global fallback channel IDs for list add/remove notifications (comma-separated)
# Per-server config: use /la-setup notifychannel #channel instead
# LIST_NOTIFY_CHANNEL_IDS=channel_id_1,channel_id_2

# Optional: Owner/admin guild ID — this server can view all server-scoped blacklist entries
# OWNER_GUILD_ID=your_guild_id_here

# How often to check the server status, in seconds (minimum: 10, default: 30)
CHECK_INTERVAL=60

# MongoDB connection URI (e.g., mongodb://localhost:27017)
MONGODB_URI=your_mongodb_uri_here

# ScraperAPI keys — fallback chain when lostark.bible blocks direct access.
# Roster deep, /la-list enrich, and /la-check roster lookups are configured
# to prefer direct lostark.bible calls and avoid ScraperAPI by default.
# Add multiple keys to rotate if one is exhausted (quota) or invalid.
SCRAPERAPI_KEY=your_scraperapi_key_here
# SCRAPERAPI_KEY_2=your_second_key_here
# SCRAPERAPI_KEY_3=your_third_key_here

# Gemini API key for screenshot OCR
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model priority list for OCR failover
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.1-flash-lite-preview,gemini-3-flash-preview

# Optional: run background Stronghold alt scan after OCR hits.
# Disabled by default to avoid many lostark.bible/ScraperAPI requests per screenshot.
# LISTCHECK_ALT_ENRICHMENT=false
# LISTCHECK_ALT_ENRICHMENT_LIMIT=1
# LISTCHECK_ALT_ENRICHMENT_CANDIDATE_LIMIT=80

# Optional: OCR/list-check performance bounds.
# /la-check limits OCR names, direct-only roster lookups, and similar-name lookups
# so repeated screenshots do not trigger large request bursts.
# LISTCHECK_MAX_NAMES=8
# LISTCHECK_ROSTER_LOOKUP_CONCURRENCY=3
# LISTCHECK_ROSTER_LOOKUP_START_SPACING_MS=150
# LISTCHECK_ROSTER_LOOKUP_TIMEOUT_MS=6000
# LISTCHECK_SIMILAR_LOOKUP_LIMIT=3
# OCR_CACHE_TTL_MS=300000
# OCR_CACHE_MAX_SIZE=100
# GUILD_MEMBERS_CACHE_TTL_MS=900000
# GUILD_MEMBERS_CACHE_MAX_SIZE=200

# Optional: Stronghold deep scan bounds.
# Command handlers keep high-fanout ScraperAPI use off unless code explicitly opts in.
# STRONGHOLD_DEEP_CANDIDATE_LIMIT=300
# STRONGHOLD_DEEP_CONCURRENCY=3
# STRONGHOLD_DEEP_CANDIDATE_TIMEOUT_MS=8000
# STRONGHOLD_DEEP_USE_SCRAPERAPI=false

# Server name(s) to monitor, comma-separated (must match playlostark.com exactly)
# Examples: Brelshaza, Valtan, Kazeros, Arcturus, Enviska, Thaemine
TARGET_SERVERS=Brelshaza
# TARGET_SERVERS=Brelshaza,Thaemine    (monitor multiple servers)
