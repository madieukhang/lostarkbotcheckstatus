# ──────────────────────────────────────────────
# Lost Ark Discord Bot – Environment Variables
# Copy this file to .env and fill in the values.
# On Railway: set these in the project's Variables tab (do NOT upload .env).
# ──────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# The text channel ID where online notifications will be sent
CHANNEL_ID=your_channel_id_here

# The role ID to mention when Brelshaza comes online
ROLE_ID=your_role_id_here

# How often to check the server status, in seconds (minimum: 10, default: 30)
CHECK_INTERVAL=60

# MongoDB connection URI (e.g., mongodb://localhost:27017)
MONGODB_URI=your_mongodb_uri_here

# Scraper API key (if required by your scraper service)
SCRAPERAPI_KEY=your_scraperapi_key_here

# Gemini API key (if required by your Gemini integration)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model name (e.g., "gemini-1.5-pro")
GEMINI_MODEL=your_gemini_model_here

# Server name to monitor (must match exactly as shown on playlostark.com status page)
# Examples: Brelshaza, Valtan, Kazeros, Arcturus, Enviska, etc.
TARGET_SERVER=Brelshaza