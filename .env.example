# LostArk LoaLogs environment reference.
# Copy this file to .env, uncomment the variables you need, and fill values there.
# Keep this example file comment-only. Do not commit real tokens, API keys, IDs, or URIs here.

# Required: Discord bot token from the Discord Developer Portal.
# DISCORD_TOKEN=

# Required: fallback channel ID for server-status notifications.
# CHANNEL_ID=

# Required: MongoDB connection URI used by the bot and optional loa-worker sidecar.
# MONGODB_URI=

# Optional: how often server status is checked, in seconds. Minimum is 10; default is 30.
# CHECK_INTERVAL=

# Optional: comma-separated Lost Ark server names to monitor. Defaults to Brelshaza.
# TARGET_SERVERS=

# Optional legacy alias for a single target server. TARGET_SERVERS takes precedence.
# TARGET_SERVER=

# Optional: comma-separated fallback channel IDs for auto-checking screenshot uploads.
# Per-server config can also be set with /la-setup autochannel.
# AUTO_CHECK_CHANNEL_IDS=

# Optional legacy alias for one auto-check channel.
# AUTO_CHECK_CHANNEL_ID=

# Optional: comma-separated fallback channel IDs for list add/remove/edit broadcasts.
# Per-server config can also be set with /la-setup notifychannel.
# LIST_NOTIFY_CHANNEL_IDS=

# Optional: owner/admin guild ID. This guild can view all server-scoped blacklist entries.
# OWNER_GUILD_ID=

# Optional: approver Discord user IDs for moderation flows, comma-separated.
# OFFICER_APPROVER_IDS=
# SENIOR_APPROVER_IDS=
# MEMBER_APPROVER_IDS=

# Optional: Gemini API key used for screenshot OCR in /la-check and auto-check flows.
# GEMINI_API_KEY=

# Optional: Gemini model priority list for OCR failover. GEMINI_MODELS takes precedence.
# GEMINI_MODELS=
# GEMINI_MODEL=

# Optional: ScraperAPI fallback keys for lostark.bible access. Keys are tried in order.
# SCRAPERAPI_KEY=
# SCRAPERAPI_KEY_2=
# SCRAPERAPI_KEY_3=

# Optional: enable post-check Stronghold enrichment for OCR/list-check hits.
# Disabled by default to avoid large request fan-out after a screenshot.
# LISTCHECK_ALT_ENRICHMENT=
# LISTCHECK_ALT_ENRICHMENT_LIMIT=
# LISTCHECK_ALT_ENRICHMENT_CANDIDATE_LIMIT=

# Optional: OCR/list-check bounds for request volume and response latency.
# LISTCHECK_MAX_NAMES=
# LISTCHECK_ROSTER_LOOKUP_CONCURRENCY=
# LISTCHECK_ROSTER_LOOKUP_START_SPACING_MS=
# LISTCHECK_ROSTER_LOOKUP_TIMEOUT_MS=
# LISTCHECK_SIMILAR_LOOKUP_LIMIT=

# Optional: short-lived OCR result cache for repeated checks of the same attachment URL.
# OCR_CACHE_TTL_MS=
# OCR_CACHE_MAX_SIZE=

# Optional: Stronghold deep scan bounds for /la-roster deep and /la-list enrich.
# STRONGHOLD_DEEP_CANDIDATE_LIMIT=
# STRONGHOLD_DEEP_CONCURRENCY=
# STRONGHOLD_DEEP_CANDIDATE_TIMEOUT_MS=
# STRONGHOLD_DEEP_USE_SCRAPERAPI=
# STRONGHOLD_DEEP_FAILURE_GUARD_MIN_CANDIDATES=
# STRONGHOLD_DEEP_FAILURE_GUARD_RATE=

# Optional: adaptive backoff bounds for deep-scan candidate fetches.
# SCAN_BACKOFF_MIN_MS=
# SCAN_BACKOFF_MAX_MS=

# Optional: in-memory cache tuning for lostark.bible character meta and guild member lists.
# META_CACHE_TTL_MS=
# META_CACHE_MAX_SIZE=
# GUILD_MEMBERS_CACHE_TTL_MS=
# GUILD_MEMBERS_CACHE_MAX_SIZE=

# Optional: base URL for display links in embeds. Controls links only, not scrape URLs.
# BIBLE_BASE_URL=

# Optional: route opt-in heavy bible fetches through the residential-IP loa-worker sidecar.
# BIBLE_WORKER_ENABLED=

# Optional: database name override for loa-worker when the URI does not include a DB path.
# MONGODB_DB_NAME=

# Optional: worker identity and queue/lease controls for the residential-IP sidecar.
# WORKER_ID=
# WORKER_JOB_LEASE_MS=
# WORKER_QUEUE_BACKPRESSURE_THRESHOLD=
